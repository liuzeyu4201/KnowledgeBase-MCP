POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432
KNOWLEDGEBASE_DATABASE_URL=postgresql+psycopg://knowledgebase:change_me@postgres:5432/knowledgebase

APP_PORT=8000
NGINX_PORT=8080

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me
