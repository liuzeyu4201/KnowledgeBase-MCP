KNOWLEDGEBASE_EMBEDDING_MODEL=text-embedding-v4
KNOWLEDGEBASE_EMBEDDING_DIMENSION=1024
KNOWLEDGEBASE_EMBEDDING_API_KEY=change_me
KNOWLEDGEBASE_EMBEDDING_TIMEOUT_SECONDS=60
