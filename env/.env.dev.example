# 统一环境示例配置。
# 使用方式：cp env/.env.dev.example env/.env.dev
# 说明：当前项目不再区分开发与生产模板，统一使用 dev 配置。
# 默认连接宿主机 Ollama，适用于本地联调与统一部署维护。

# PostgreSQL 基础配置
POSTGRES_DB=knowledgebase
POSTGRES_USER=knowledgebase
POSTGRES_PASSWORD=knowledgebase
POSTGRES_PORT=5432
KNOWLEDGEBASE_DATABASE_URL=postgresql+psycopg://knowledgebase:knowledgebase@postgres:5432/knowledgebase

# Web 入口端口
APP_PORT=8000
NGINX_PORT=8080

# MinIO 容器与控制台端口
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Milvus 对外端口
MILVUS_PORT=19530
MILVUS_WEB_PORT=9091

# Embedding 配置
# provider=ollama 时，base_url 指向宿主机 OpenAI 兼容接口。
# api_key 对 ollama 可留空。
KNOWLEDGEBASE_EMBEDDING_PROVIDER=ollama
KNOWLEDGEBASE_EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
KNOWLEDGEBASE_EMBEDDING_MODEL=qwen3-embedding:0.6b
KNOWLEDGEBASE_EMBEDDING_DIMENSION=1024
KNOWLEDGEBASE_EMBEDDING_API_KEY=
KNOWLEDGEBASE_EMBEDDING_TIMEOUT_SECONDS=60
KNOWLEDGEBASE_EMBEDDING_MAX_BATCH_SIZE=16

# 文件存储与对象存储配置
KNOWLEDGEBASE_STORAGE_ROOT=/app/data/storage
KNOWLEDGEBASE_OBJECT_STORAGE_PROVIDER=minio
KNOWLEDGEBASE_MINIO_ENDPOINT=minio:9000
KNOWLEDGEBASE_MINIO_ACCESS_KEY=minioadmin
KNOWLEDGEBASE_MINIO_SECRET_KEY=minioadmin
KNOWLEDGEBASE_MINIO_SECURE=false
KNOWLEDGEBASE_MINIO_STAGED_BUCKET=kb-staged-files
KNOWLEDGEBASE_MINIO_DOCUMENT_BUCKET=kb-documents

# 导入与检索相关配置
KNOWLEDGEBASE_STAGED_FILE_TTL_SECONDS=300
KNOWLEDGEBASE_MILVUS_ANALYZER=language_identifier

# 当前模板允许重建 collection，便于初始化与调试。
KNOWLEDGEBASE_MILVUS_RECREATE_COLLECTION=true
